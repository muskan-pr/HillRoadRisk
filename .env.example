# ===========================================
# HillRoadRisk Environment Configuration
# Copy this to .env and fill in values
# ===========================================

# Database (Local Docker or Supabase)
DATABASE_URL=postgresql://hillrisk:hillrisk@localhost:5432/hillroadrisk
# For Supabase (production):
# DATABASE_URL=postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres

# API Settings
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
API_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Weather Data
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1

# Uttarakhand Bounding Box
REGION_MIN_LAT=29.0
REGION_MAX_LAT=31.5
REGION_MIN_LON=77.0
REGION_MAX_LON=81.0

# Data Directories
DATA_DIR=./data
DEM_DIR=./data/dem
MODELS_DIR=./data/models
PROCESSED_DIR=./data/processed

# MLflow
MLFLOW_TRACKING_URI=sqlite:///mlflow.db

# Alert Engine (Phase 2)
# RESEND_API_KEY=re_xxxxxxxxxxxx
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=

# Admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
SECRET_KEY=change-this-to-a-random-secret-key
